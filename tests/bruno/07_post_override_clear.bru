meta {
  name: Override - Clear
  type: http
  seq: 7
}

post {
  url: {{base_url}}/api/override
  body: json
  auth: none
}

body:json {
  {
    "action": "clear"
  }
}

tests {
  test("responds 200", function() {
    expect(res.status).to.equal(200);
  });

  test("ok is true", function() {
    expect(res.body.ok).to.be.true;
  });

  test("relay_state is a known value after auto-check", function() {
    expect(res.body.relay_state).to.be.oneOf(["suppressed", "allowed"]);
  });
}
